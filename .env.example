# Application Configuration
APP_NAME=RivaAI
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Telephony Configuration - India-compatible
TELEPHONY_PROVIDER=amazon_connect  # Options: amazon_connect, exotel, twilio

# Amazon Connect (Primary for India)
AMAZON_CONNECT_INSTANCE_ID=your_instance_id
AMAZON_CONNECT_CONTACT_FLOW_ID=your_contact_flow_id
AMAZON_CONNECT_PHONE_NUMBER=+91xxxxxxxxxx

# Exotel (Alternative for India)
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_sid
EXOTEL_PHONE_NUMBER=+91xxxxxxxxxx

# Twilio (Fallback - limited India support)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Speech Services - AWS Native (Primary for low latency)
USE_AWS_SPEECH=true

# AWS Transcribe (STT)
TRANSCRIBE_LANGUAGE_CODE=hi-IN
TRANSCRIBE_ENABLE_PARTIAL_RESULTS=true

# AWS Polly (TTS)
POLLY_VOICE_ID=Aditi  # Hindi voice
POLLY_ENGINE=neural

# Speech-to-Speech Model (Future optimization)
USE_SPEECH_TO_SPEECH=false
SPEECH_MODEL_PROVIDER=bedrock

# Fallback: External Speech Services
DEEPGRAM_API_KEY=your_deepgram_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS Bedrock - LLM Services (Primary)
USE_BEDROCK=true
BEDROCK_MAIN_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_FAST_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024

# Fallback: External LLM Services (if USE_BEDROCK=false)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key
MAIN_LLM_MODEL=gpt-4-turbo-preview
SMALL_LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=text-embedding-3-large

# Database Configuration (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rivaai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
SESSION_TTL_HOURS=24

# Latency Budgets (milliseconds)
CALL_ESTABLISHMENT_LATENCY_MS=3000
STT_PARTIAL_LATENCY_MS=500
BARGE_IN_LATENCY_MS=300
TTS_FIRST_CHUNK_LATENCY_MS=800
SIMPLE_INTENT_LATENCY_MS=500
CLARIFICATION_LATENCY_MS=1200
COMPLEX_DECISION_LATENCY_MS=3000

# Confidence Thresholds
STT_CONFIDENCE_THRESHOLD=0.6
DECISION_CONFIDENCE_THRESHOLD=0.8
RETRIEVAL_RELEVANCE_THRESHOLD=0.7

# Safety Configuration
CIRCUIT_BREAKER_HALT_LATENCY_MS=100
SAFETY_MESSAGE_PATH=assets/safety_messages

# Retrieval Configuration
RETRIEVAL_TOP_K=5
GRAPH_TRAVERSAL_DEPTH=2
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_GRAPH_WEIGHT=0.4

# Response Generation
MAX_RESPONSE_TOKENS=40
MAX_SENTENCE_WORDS=15

# Monitoring
LOG_LEVEL=INFO
ENABLE_TRACING=false
METRICS_PORT=9090
